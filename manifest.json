{
  "manifest_version": 3,
  "name": "Shorts Blocker for YouTube",
  "version": "1.1.0",
  "description": "Hides YouTube Shorts from your feed, search, sidebar, and channel pages — keeping your YouTube experience distraction-free.",
  "homepage_url": "https://github.com/farithadnan/youtube-short-hider",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["*://*.youtube.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Shorts Blocker for YouTube",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
